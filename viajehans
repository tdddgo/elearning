<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>España — Madrid & Barcelona</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
:root {
  --m:#C1440E; --ml:#FBF0EA; --b:#1B5EA8; --bl:#E4EEF9;
  --bg:#F4EFE5; --paper:#FDFAF4; --ink:#1C1810; --ink2:#5C5040;
  --ink3:#9A8C78; --line:#E0D8C8; --sw:360px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:var(--bg);display:flex;overflow:hidden}

#side{width:var(--sw);min-width:var(--sw);height:100vh;background:var(--paper);border-right:1px solid var(--line);display:flex;flex-direction:column;overflow:hidden;z-index:1000}
.s-head{padding:18px 20px 0;flex-shrink:0}
.s-title{font-family:'Playfair Display',serif;font-size:21px;font-weight:700;color:var(--ink);letter-spacing:-0.3px}
.s-sub{font-size:11px;color:var(--ink3);font-weight:300;margin-top:2px;text-transform:uppercase;letter-spacing:.8px}
.tabs{display:flex;margin-top:14px;border-bottom:1px solid var(--line)}
.tab{flex:1;padding:9px 0 8px;font-size:13px;font-weight:500;border:none;background:transparent;color:var(--ink3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;font-family:'DM Sans',sans-serif}
.tab.on.m{color:var(--m);border-bottom-color:var(--m)}
.tab.on.b{color:var(--b);border-bottom-color:var(--b)}
.tab:not(.on):hover{color:var(--ink2)}

.prog-wrap{padding:11px 20px 8px;flex-shrink:0}
.prog-row{display:flex;justify-content:space-between;font-size:11.5px;color:var(--ink3);font-weight:300;margin-bottom:5px}
.pbar{height:3px;background:var(--line);border-radius:2px;overflow:hidden}
.pfill{height:100%;width:0%;border-radius:2px;transition:width .35s ease}
.pfill.m{background:var(--m)}.pfill.b{background:var(--b)}

#scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding-bottom:24px}
#scroll::-webkit-scrollbar{width:3px}
#scroll::-webkit-scrollbar-thumb{background:var(--line);border-radius:2px}

.grp-head{display:flex;align-items:center;gap:7px;padding:7px 20px;cursor:pointer;user-select:none;transition:background .12s}
.grp-head:hover{background:var(--bg)}
.g-ico{font-size:12px;width:16px;text-align:center;flex-shrink:0}
.g-lbl{font-size:10.5px;font-weight:500;letter-spacing:.7px;text-transform:uppercase;color:var(--ink3);flex:1}
.g-cnt{font-size:10.5px;color:var(--ink3);font-weight:300}
.g-arr{font-size:9px;color:var(--ink3);transition:transform .18s}
.g-arr.open{transform:rotate(90deg)}
.g-items.hide{display:none}

.row{display:flex;align-items:flex-start;gap:9px;padding:8px 20px 8px 17px;cursor:pointer;border-left:3px solid transparent;transition:background .1s}
.row:hover{background:var(--bg)}
.row.lit.m{border-left-color:var(--m);background:var(--ml)}
.row.lit.b{border-left-color:var(--b);background:var(--bl)}
.box{width:16px;height:16px;min-width:16px;border-radius:3px;border:1.5px solid var(--line);display:flex;align-items:center;justify-content:center;margin-top:2px;flex-shrink:0;transition:background .14s,border-color .14s}
.row.done .box{border-color:transparent}
.row.done.m .box{background:var(--m)}.row.done.b .box{background:var(--b)}
.ck{display:none}.row.done .ck{display:block}
.ri{flex:1}
.rn{font-size:13px;font-weight:400;color:var(--ink);line-height:1.3}
.row.done .rn{color:var(--ink3);text-decoration:line-through}
.rt{font-size:11.5px;color:var(--ink3);font-weight:300;margin-top:1px;line-height:1.4}
.row.done .rt{color:var(--line)}
.tags{display:flex;gap:4px;margin-top:4px;flex-wrap:wrap}
.tag{font-size:10px;padding:1px 7px;border-radius:20px}
.tmu{background:#FDE8E0;color:#A33010}.twk{background:#E2F0D4;color:#2E6010}.tni{background:#E8E4F8;color:#4030A0}

#map{flex:1;height:100vh;position:relative;background:#E8E2D8}
#leg{position:absolute;bottom:20px;right:20px;background:var(--paper);border:1px solid var(--line);border-radius:8px;padding:10px 14px;font-size:11px;color:var(--ink3);z-index:500;font-weight:300;line-height:1.9;pointer-events:none}
.ldot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;vertical-align:middle}

.leaflet-popup-content-wrapper{background:var(--paper);border:1px solid var(--line);border-radius:10px;box-shadow:0 6px 24px rgba(0,0,0,.13);padding:0;overflow:hidden}
.leaflet-popup-content{margin:0;padding:0;min-width:200px}
.leaflet-popup-tip{background:var(--paper)}
.pi{padding:12px 16px 10px}
.pn{font-family:'Playfair Display',serif;font-size:14px;color:var(--ink);margin-bottom:4px}
.pt{font-size:11.5px;color:var(--ink2);font-weight:300;line-height:1.4}
.ptags{display:flex;gap:4px;margin-top:6px;flex-wrap:wrap}
.pact{display:block;width:100%;padding:8px 16px;border:none;border-top:1px solid var(--line);background:transparent;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:background .1s}
.pact:hover{background:var(--bg)}
.pact.m{color:var(--m)}.pact.b{color:var(--b)}.pact.done{color:var(--ink3)}

@media(max-width:680px){
  :root{--sw:100vw}
  html,body{flex-direction:column}
  #side{width:100%;min-width:unset;height:55vh;border-right:none;border-bottom:1px solid var(--line)}
  #map{height:45vh}
}
</style>
</head>
<body>
<div id="side">
  <div class="s-head">
    <div class="s-title">España 🗺</div>
    <div class="s-sub">Madrid · Barcelona · Tu ruta</div>
    <div class="tabs">
      <button class="tab on m" data-c="madrid" onclick="sw('madrid')">Madrid</button>
      <button class="tab b" data-c="barcelona" onclick="sw('barcelona')">Barcelona</button>
    </div>
  </div>
  <div class="prog-wrap">
    <div class="prog-row"><span id="plbl">0 lugares visitados</span><span id="ppct">0%</span></div>
    <div class="pbar"><div class="pfill m" id="pf"></div></div>
  </div>
  <div id="scroll"><div id="list"></div></div>
</div>
<div id="map">
  <div id="leg">
    <div><span class="ldot" style="background:#ccc;border:1.5px solid #999"></span>Pendiente</div>
    <div><span class="ldot" id="lv" style="background:#C1440E"></span>Visitado</div>
  </div>
</div>

<script>
const D={
  madrid:{c:'m',col:'#C1440E',center:[40.416,-3.703],zoom:13,secs:[
    {i:'🏛️',l:'Museos & monumentos',items:[
      {n:'Museo del Prado',t:'Uno de los mejores del mundo — reserva online',tags:['must'],lat:40.4138,lng:-3.6922},
      {n:'Museo Reina Sofía',t:'El Guernica de Picasso está aquí',tags:['must'],lat:40.4085,lng:-3.6941},
      {n:'Palacio Real',t:'La fachada desde Plaza de Oriente es increíble',tags:['walk'],lat:40.4180,lng:-3.7143},
      {n:'Templo de Debod',t:'Atardecer épico — llega 30 min antes',tags:['night','walk'],lat:40.4236,lng:-3.7188},
      {n:'Catedral de la Almudena',t:'Sube a la cúpula — vistas 360° gratuitas',tags:['walk'],lat:40.4155,lng:-3.7145},
    ]},
    {i:'🚶',l:'Barrios para caminar',items:[
      {n:'Malasaña',t:'El barrio más joven y alternativo',tags:['walk'],lat:40.4268,lng:-3.7055},
      {n:'Lavapiés',t:'Multicultural y auténtico, bares pequeños',tags:['walk'],lat:40.4069,lng:-3.7031},
      {n:'La Latina',t:'Domingos = El Rastro + tapas en Cava Baja',tags:['walk','must'],lat:40.4132,lng:-3.7100},
      {n:'Chueca',t:'Colorido, animado, buena gastronomía',tags:['walk'],lat:40.4236,lng:-3.6988},
      {n:'Barrio de las Letras',t:'Donde vivían Lope de Vega y Quevedo',tags:['walk'],lat:40.4145,lng:-3.6972},
    ]},
    {i:'🌿',l:'Parques & miradores',items:[
      {n:'Parque del Retiro',t:'El pulmón de Madrid — gratis y espectacular',tags:['walk','must'],lat:40.4153,lng:-3.6844},
      {n:'Cerro del Tío Pío',t:'"Las 7 tetas" — el mejor atardecer de la ciudad',tags:['night','walk'],lat:40.3875,lng:-3.6678},
      {n:'Jardines de Sabatini',t:'Junto al Palacio Real, muy tranquilos',tags:['walk'],lat:40.4192,lng:-3.7143},
    ]},
    {i:'🍷',l:'Plazas, mercados & comida',items:[
      {n:'Plaza Mayor',t:'El corazón histórico de Madrid',tags:['must'],lat:40.4155,lng:-3.7074},
      {n:'Gran Vía',t:'Arquitectura imponente — camínala de punta a punta',tags:['walk'],lat:40.4200,lng:-3.7025},
      {n:'Mercado de San Miguel',t:'Ideal para picar de todo',tags:[],lat:40.4151,lng:-3.7087},
      {n:'Chocolatería San Ginés',t:'Desde 1894 — churros a medianoche son un ritual',tags:['night','must'],lat:40.4153,lng:-3.7079},
      {n:'Calle Cava Baja',t:'La mejor calle de tapas de Madrid',tags:['must'],lat:40.4127,lng:-3.7090},
      {n:'El Rastro',t:'Mercadillo dominguero icónico — solo domingos',tags:[],lat:40.4091,lng:-3.7069},
    ]},
  ]},
  barcelona:{c:'b',col:'#1B5EA8',center:[41.392,2.168],zoom:13,secs:[
    {i:'🏗️',l:'Gaudí & modernismo',items:[
      {n:'Sagrada Família',t:'Reserva con guía y sube a las torres',tags:['must'],lat:41.4036,lng:2.1744},
      {n:'Park Güell',t:'Zona monumental con ticket — llega temprano',tags:['must','walk'],lat:41.4145,lng:2.1527},
      {n:'Casa Batlló',t:'La fachada nocturna es otra dimensión',tags:['night'],lat:41.3916,lng:2.1649},
      {n:'Casa Milà / La Pedrera',t:'La azotea es de otro planeta',tags:['must'],lat:41.3954,lng:2.1619},
      {n:'Palau de la Música Catalana',t:'Joya del modernismo — tour o concierto',tags:['must'],lat:41.3875,lng:2.1752},
    ]},
    {i:'🚶',l:'Barrios para caminar',items:[
      {n:'Barrio Gótico',t:'Perderse aquí es el plan — plazas medievales',tags:['walk','must'],lat:41.3832,lng:2.1762},
      {n:'El Born / Sant Pere',t:'El barrio más cool — tiendas y bares',tags:['walk','must'],lat:41.3851,lng:2.1821},
      {n:'Gràcia',t:'Bohemio y local — Plaza del Sol y Plaza de la Vila',tags:['walk'],lat:41.4027,lng:2.1565},
      {n:'El Raval',t:'Arte, diversidad y el MACBA — muy auténtico',tags:['walk'],lat:41.3803,lng:2.1676},
      {n:'Barceloneta',t:'El barrio de la playa — paseo marítimo',tags:['walk'],lat:41.3796,lng:2.1892},
    ]},
    {i:'🌅',l:'Vistas & naturaleza',items:[
      {n:'Bunkers del Carmel',t:'El mirador secreto — mejor panorámica al atardecer',tags:['must','night','walk'],lat:41.4260,lng:2.1671},
      {n:'Montjuïc',t:'A pie o cable car — castillo, jardines y mar',tags:['walk'],lat:41.3636,lng:2.1575},
      {n:'Tibidabo',t:'El parque de atracciones más antiguo de España',tags:[],lat:41.4217,lng:2.1183},
      {n:'Playa de la Barceloneta',t:'Un baño en el Mediterráneo es obligatorio',tags:['must'],lat:41.3796,lng:2.1908},
    ]},
    {i:'🍷',l:'Mercados, bares & comida',items:[
      {n:'Mercado de La Boqueria',t:'Icónico — ve temprano y compra fruta fresca',tags:[],lat:41.3817,lng:2.1718},
      {n:'Mercado de Santa Caterina',t:'Más local y auténtico que La Boqueria',tags:['must'],lat:41.3856,lng:2.1787},
      {n:'El Xampanyet',t:'Bar de cava histórico en El Born',tags:['must','night'],lat:41.3848,lng:2.1826},
      {n:'Bar Marsella',t:'El bar más antiguo de Barcelona — 1820',tags:['night'],lat:41.3797,lng:2.1725},
      {n:'Passeig de Gràcia',t:'Avenida elegante con la Manzana de la Discordia',tags:['walk'],lat:41.3916,lng:2.1649},
    ]},
  ]}
};

let city='madrid',chk={madrid:{},barcelona:{}},open={madrid:{},barcelona:{}};
let map,markers={};

function initMap(){
  map=L.map('map',{center:D.madrid.center,zoom:D.madrid.zoom,zoomControl:false});
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© <a href="https://openstreetmap.org">OpenStreetMap</a>',maxZoom:19
  }).addTo(map);
  L.control.zoom({position:'topright'}).addTo(map);
  addAllMarkers();
}

function pinIcon(col,done){
  const bg=done?col:'#fff',stroke=done?col:'#aaa',dot=done?'#fff':col;
  return L.divIcon({className:'',
    html:`<svg width="26" height="34" viewBox="0 0 26 34" xmlns="http://www.w3.org/2000/svg">
      <path d="M13 1C7 1 2 6 2 12c0 8 11 21 11 21S24 20 24 12C24 6 19 1 13 1z" fill="${bg}" stroke="${stroke}" stroke-width="1.5"/>
      <circle cx="13" cy="12" r="4.5" fill="${dot}"/>
    </svg>`,
    iconSize:[26,34],iconAnchor:[13,34],popupAnchor:[0,-36]
  });
}

function tagBadge(t){
  if(t==='must') return`<span style="font-size:10px;padding:1px 7px;border-radius:20px;background:#FDE8E0;color:#A33010;">imprescindible</span>`;
  if(t==='walk') return`<span style="font-size:10px;padding:1px 7px;border-radius:20px;background:#E2F0D4;color:#2E6010;">a pie</span>`;
  if(t==='night') return`<span style="font-size:10px;padding:1px 7px;border-radius:20px;background:#E8E4F8;color:#4030A0;">noche</span>`;
  return'';
}

function popupContent(ct,si,ii){
  const item=D[ct].secs[si].items[ii];
  const done=!!chk[ct][`${si}-${ii}`];
  const cd=D[ct];
  const tags=item.tags.map(tagBadge).join('');
  return`<div class="pi">
    <div class="pn">${item.n}</div>
    <div class="pt">${item.t}</div>
    ${tags?`<div class="ptags">${tags}</div>`:''}
  </div>
  <button class="pact ${cd.c}${done?' done':''}" onclick="popToggle('${ct}',${si},${ii})">
    ${done?'✓ Visitado — desmarcar':'Marcar como visitado'}
  </button>`;
}

function addAllMarkers(){
  ['madrid','barcelona'].forEach(ct=>{
    D[ct].secs.forEach((sec,si)=>{
      sec.items.forEach((item,ii)=>{
        const key=`${ct}-${si}-${ii}`;
        const done=!!chk[ct][`${si}-${ii}`];
        const mk=L.marker([item.lat,item.lng],{icon:pinIcon(D[ct].col,done)});
        mk.bindPopup(()=>popupContent(ct,si,ii),{maxWidth:240});
        mk.on('click',()=>{
          if(ct!==city)sw(ct);
          setTimeout(()=>highlight(si,ii),350);
        });
        mk.addTo(map);
        markers[key]=mk;
      });
    });
  });
}

function refreshMarker(ct,si,ii){
  const key=`${ct}-${si}-${ii}`;
  const done=!!chk[ct][`${si}-${ii}`];
  if(markers[key]){
    markers[key].setIcon(pinIcon(D[ct].col,done));
    if(markers[key].isPopupOpen()) markers[key].setPopupContent(popupContent(ct,si,ii));
  }
}

function popToggle(ct,si,ii){
  const k=`${si}-${ii}`;
  chk[ct][k]=!chk[ct][k];
  refreshMarker(ct,si,ii);
  if(ct===city){renderList();updateProg();}
}

function toggle(ct,si,ii){
  const k=`${si}-${ii}`;
  chk[ct][k]=!chk[ct][k];
  refreshMarker(ct,si,ii);
  renderList();updateProg();
}

function highlight(si,ii){
  document.querySelectorAll('.row').forEach(r=>r.classList.remove('lit','m','b'));
  const el=document.querySelector(`.row[data-si="${si}"][data-ii="${ii}"]`);
  if(el){el.classList.add('lit',D[city].c);el.scrollIntoView({behavior:'smooth',block:'center'});}
}

function sw(ct){
  city=ct;
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('on',t.dataset.c===ct));
  document.getElementById('pf').className=`pfill ${D[ct].c}`;
  document.getElementById('lv').style.background=D[ct].col;
  map.flyTo(D[ct].center,D[ct].zoom,{duration:1.1,easeLinearity:.5});
  renderList();updateProg();
}

function toggleSec(si){
  open[city][si]=open[city][si]===false?true:false;
  renderList();
}

function updateProg(){
  const cd=D[city];let total=0,done=0;
  cd.secs.forEach((s,si)=>s.items.forEach((_,ii)=>{total++;if(chk[city][`${si}-${ii}`])done++;}));
  const pct=total?Math.round(done/total*100):0;
  document.getElementById('pf').style.width=pct+'%';
  document.getElementById('plbl').textContent=`${done} de ${total} lugares visitados`;
  document.getElementById('ppct').textContent=pct+'%';
}

function onRow(e,ct,si,ii){
  const rect=e.currentTarget.getBoundingClientRect();
  if(e.clientX-rect.left<rect.width*.65){
    toggle(ct,si,ii);
  } else {
    const item=D[ct].secs[si].items[ii];
    map.flyTo([item.lat,item.lng],17,{duration:.8});
    setTimeout(()=>{const key=`${ct}-${si}-${ii}`;if(markers[key])markers[key].openPopup();},900);
  }
}

function renderList(){
  const cd=D[city],cc=D[city].c;
  let html='';
  cd.secs.forEach((sec,si)=>{
    const isOpen=open[city][si]!==false;
    const doneSec=sec.items.filter((_,ii)=>chk[city][`${si}-${ii}`]).length;
    html+=`<div class="grp">
      <div class="grp-head" onclick="toggleSec(${si})">
        <span class="g-ico">${sec.i}</span>
        <span class="g-lbl">${sec.l}</span>
        <span class="g-cnt">${doneSec}/${sec.items.length}</span>
        <span class="g-arr ${isOpen?'open':''}">▶</span>
      </div>
      <div class="g-items ${isOpen?'':'hide'}">`;
    sec.items.forEach((item,ii)=>{
      const done=!!chk[city][`${si}-${ii}`];
      const thtml=item.tags.map(t=>{
        if(t==='must')return'<span class="tag tmu">imprescindible</span>';
        if(t==='walk')return'<span class="tag twk">a pie</span>';
        if(t==='night')return'<span class="tag tni">noche</span>';
        return'';
      }).join('');
      html+=`<div class="row${done?' done '+cc:''}" data-si="${si}" data-ii="${ii}" onclick="onRow(event,'${city}',${si},${ii})">
        <div class="box"><svg class="ck" width="9" height="7" viewBox="0 0 9 7" fill="none"><path d="M1 3.5L3 5.5L8 1" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="ri">
          <div class="rn">${item.n}</div>
          <div class="rt">${item.t}</div>
          ${thtml?`<div class="tags">${thtml}</div>`:''}
        </div>
      </div>`;
    });
    html+=`</div></div>`;
  });
  document.getElementById('list').innerHTML=html;
}

renderList();
updateProg();
window.addEventListener('load',initMap);
</script>
</body>
</html>
