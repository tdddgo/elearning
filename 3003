  { name: 'Psicoterapia Online', code: 'DPODA1AR', leads: 139, gasto: 480823, freq: 5.1, status: 'yellow', accion: 'revisar', note: 'frecuencia alta' },
  { name: 'Marketing Digital', code: 'DCMDI1AR', leads: 118, gasto: 426496, freq: 3.2, status: 'yellow', accion: 'revisar', note: 'consolidar' },
  { name: 'Comunicaciones Internas', code: 'DCOIN1AR', leads: 86, gasto: 312321, freq: 2.5, status: 'yellow', accion: 'revisar', note: '' },
  { name: 'E-learning', code: 'DELEA1AR', leads: 82, gasto: 628982, freq: 2.8, status: 'red', accion: 'revisar', note: 'rediseño' },
  { name: 'Compliance', code: 'DCIGR1AR', leads: 49, gasto: 502192, freq: 3.2, status: 'red', accion: 'pausar parcial', note: 'parar carousel' },
  { name: 'PSIDIP26 Psicología', code: 'PSIDIP26', leads: 11, gasto: 190914, freq: 2.8, status: 'red', accion: 'evaluar', note: 'not_delivering' },
  { name: 'Brand / MÁS General', code: 'Brand campaigns', leads: 29, gasto: 551505, freq: 3.4, status: 'red', accion: 'pausar', note: '' },
];

const maxLeads = Math.max(...programs.map(p => p.leads));
const maxGasto = Math.max(...programs.map(p => p.gasto));

function fmt(n) { return n.toLocaleString('es-CL'); }

function cplClass(cpl) {
  if (cpl < 2000) return 'cpl-green';
  if (cpl < 5000) return 'cpl-yellow';
  return 'cpl-red';
}

function barColor(status) {
  if (status === 'green') return '#4ade80';
  if (status === 'yellow') return '#facc15';
  return '#f87171';
}

function accionTag(accion) {
  if (accion.includes('escalar')) return '<span class="tag tag-escalar">Escalar</span>';
  if (accion.includes('pausar')) return '<span class="tag tag-pausar">Pausar</span>';
  if (accion.includes('revisar')) return '<span class="tag tag-revisar">Revisar</span>';
  return '<span class="tag" style="background:rgba(107,114,128,0.08);color:#6b7280;border:1px solid #252830">Mantener</span>';
}

function noteHtml(p) {
  if (!p.note) return '';
  if (p.note === 'not_delivering') return ' <span class="freq-warn">paused</span>';
  if (p.note === 'frecuencia alta') return ` <span class="freq-warn">freq ${p.freq.toFixed(1)}</span>`;
  return ` <span class="freq-warn">${p.note}</span>`;
}

function renderTable(filter) {
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = programs.map(p => {
    const cpl = Math.round(p.gasto / p.leads);
    const leadPct = Math.round((p.leads / maxLeads) * 100);
    const dotClass = `dot-${p.status}`;
    const hidden = (filter !== 'all' && p.status !== filter) ? 'hidden' : '';

    return `<tr class="${hidden}" data-status="${p.status}">
      <td>
        <div class="prog-name"><span class="dot ${dotClass}"></span>${p.name}${noteHtml(p)}</div>
        <div class="prog-code">${p.code}</div>
      </td>
      <td class="num">${fmt(p.leads)}</td>
      <td class="num">$${fmt(p.gasto)}</td>
      <td class="num"><span class="cpl-chip ${cplClass(cpl)}">$${fmt(cpl)}</span></td>
      <td style="width:160px">
        <div class="bar-wrap">
          <div class="bar-track"><div class="bar-fill" style="width:${leadPct}%;background:${barColor(p.status)}"></div></div>
          <div class="bar-num">${leadPct}%</div>
        </div>
      </td>
      <td>${p.status === 'green' ? '🟢 Óptimo' : p.status === 'yellow' ? '🟡 Revisar' : '🔴 Urgente'}</td>
      <td>${accionTag(p.accion)}</td>
    </tr>`;
  }).join('');
}

function filterTable(filter, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderTable(filter);
}

renderTable('all');
</script>
</body>
</html>
