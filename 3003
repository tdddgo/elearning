<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0b0f;
    --surface: #111318;
    --surface2: #1a1d25;
    --border: #252830;
    --text: #e8eaf0;
    --text-muted: #6b7280;
    --text-dim: #3d4251;
    --accent: #4ade80;
    --accent2: #facc15;
    --danger: #f87171;
    --warn: #fb923c;
    --blue: #60a5fa;
    --mono: 'DM Mono', monospace;
    --head: 'Syne', sans-serif;
    --body: 'Outfit', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--body);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
  }

  /* GRID NOISE BG */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: 
      linear-gradient(rgba(74,222,128,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(74,222,128,0.02) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

  /* HEADER */
  header {
    padding: 36px 0 28px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .header-inner { display: flex; align-items: flex-end; justify-content: space-between; }
  .brand-tag {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  h1 {
    font-family: var(--head);
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.5px;
  }
  .period {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  /* KPI CARDS */
  .kpis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .kpi {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .kpi:hover { border-color: var(--accent); }
  .kpi::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--kpi-color, var(--accent));
    opacity: 0.6;
  }
  .kpi-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 10px;
  }
  .kpi-val {
    font-family: var(--head);
    font-size: 30px;
    font-weight: 800;
    color: var(--kpi-color, var(--text));
    line-height: 1;
  }
  .kpi-sub {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 6px;
  }

  /* SECTION TITLES */
  .section-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .section-title {
    font-family: var(--head);
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }
  .section-badge {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 2px 8px;
    border-radius: 20px;
  }

  /* FILTER TABS */
  .filters {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }
  .filter-btn {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); }
  .filter-btn.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 500; }
  .filter-btn.warn.active { background: var(--accent2); border-color: var(--accent2); }
  .filter-btn.danger.active { background: var(--danger); border-color: var(--danger); }

  /* TABLE */
  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 32px;
  }
  table { width: 100%; border-collapse: collapse; }
  thead tr {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }
  th {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 12px 16px;
    text-align: left;
    font-weight: 400;
  }
  th.num { text-align: right; }
  td {
    padding: 13px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    vertical-align: middle;
  }
  td.num { text-align: right; font-family: var(--mono); font-size: 12px; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr { transition: background 0.12s; }
  tbody tr:hover { background: var(--surface2); }
  tbody tr.hidden { display: none; }

  .prog-name { font-weight: 500; color: var(--text); }
  .prog-code { font-family: var(--mono); font-size: 10px; color: var(--text-muted); margin-top: 2px; }

  /* SEMAFORO */
  .dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    flex-shrink: 0;
  }
  .dot-green { background: var(--accent); box-shadow: 0 0 6px rgba(74,222,128,0.5); }
  .dot-yellow { background: var(--accent2); box-shadow: 0 0 6px rgba(250,204,21,0.5); }
  .dot-red { background: var(--danger); box-shadow: 0 0 6px rgba(248,113,113,0.5); }

  /* CPL BADGE */
  .cpl-chip {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    display: inline-block;
  }
  .cpl-green { background: rgba(74,222,128,0.1); color: var(--accent); border: 1px solid rgba(74,222,128,0.2); }
  .cpl-yellow { background: rgba(250,204,21,0.08); color: var(--accent2); border: 1px solid rgba(250,204,21,0.2); }
  .cpl-red { background: rgba(248,113,113,0.08); color: var(--danger); border: 1px solid rgba(248,113,113,0.2); }

  /* BAR CELL */
  .bar-wrap { display: flex; align-items: center; gap: 8px; }
  .bar-track { flex: 1; height: 4px; background: var(--border); border-radius: 2px; }
  .bar-fill { height: 100%; border-radius: 2px; transition: width 0.4s ease; }
  .bar-num { font-family: var(--mono); font-size: 11px; color: var(--text-muted); width: 36px; text-align: right; }

  /* ALERT TAG */
  .tag {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
  }
  .tag-escalar { background: rgba(74,222,128,0.1); color: var(--accent); border: 1px solid rgba(74,222,128,0.15); }
  .tag-revisar { background: rgba(250,204,21,0.08); color: var(--accent2); border: 1px solid rgba(250,204,21,0.15); }
  .tag-pausar { background: rgba(248,113,113,0.08); color: var(--danger); border: 1px solid rgba(248,113,113,0.15); }
  .tag-atención { background: rgba(251,146,60,0.08); color: var(--warn); border: 1px solid rgba(251,146,60,0.15); }

  /* OPORTUNIDADES */
  .opps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 40px;
  }
  .opp-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    border-left: 3px solid transparent;
    transition: transform 0.15s, border-color 0.15s;
  }
  .opp-card:hover { transform: translateX(2px); }
  .opp-card.red { border-left-color: var(--danger); }
  .opp-card.green { border-left-color: var(--accent); }
  .opp-card.yellow { border-left-color: var(--accent2); }
  .opp-card.orange { border-left-color: var(--warn); }

  .opp-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 8px; gap: 10px; }
  .opp-title { font-weight: 600; font-size: 13px; color: var(--text); line-height: 1.3; }
  .opp-body { font-size: 12px; color: var(--text-muted); line-height: 1.5; }
  .opp-impact {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--border);
  }
  .opp-impact span { color: var(--text-muted); }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 20px 0;
    margin-top: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-text { font-family: var(--mono); font-size: 10px; color: var(--text-dim); letter-spacing: 0.1em; }

  /* FREQUENCY WARNING */
  .freq-warn {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--warn);
    background: rgba(251,146,60,0.06);
    border: 1px solid rgba(251,146,60,0.15);
    border-radius: 4px;
    padding: 2px 6px;
    display: inline-block;
  }

  /* ANIMATION */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .kpi { animation: fadeUp 0.4s ease both; }
  .kpi:nth-child(1) { animation-delay: 0.05s; }
  .kpi:nth-child(2) { animation-delay: 0.1s; }
  .kpi:nth-child(3) { animation-delay: 0.15s; }
  .kpi:nth-child(4) { animation-delay: 0.2s; }
</style>
</head>
