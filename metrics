// ── COMPARAR PERÍODOS ────────────────────────────────────────
function ComparTab() {
  const [p1,setP1]=useState({camps:[],sets:[],ads:[]});
  const [p2,setP2]=useState({camps:[],sets:[],ads:[]});
  const [fs1,setFs1]=useState({c:"",s:"",a:""});
  const [fs2,setFs2]=useState({c:"",s:"",a:""});

  const hf=(period,key,parser)=>(rows,st)=>{
    if(period===1){setFs1(f=>({...f,[key]:st}));if(st==="ok")setP1(d=>({...d,[key==="c"?"camps":key==="s"?"sets":"ads"]:parser(rows)}));}
    else{setFs2(f=>({...f,[key]:st}));if(st==="ok")setP2(d=>({...d,[key==="c"?"camps":key==="s"?"sets":"ads"]:parser(rows)}));}
  };

  const s1=p1.camps.reduce((a,c)=>a+c.gasto,0), s2=p2.camps.reduce((a,c)=>a+c.gasto,0);
  const l1=p1.camps.reduce((a,c)=>a+c.leads,0), l2=p2.camps.reduce((a,c)=>a+c.leads,0);
  const c1=l1>0?s1/l1:0, c2=l2>0?s2/l2:0;
  const hasBoth=p1.camps.length>0&&p2.camps.length>0;

  const Chg=({v1,v2,inv})=>{
    if(!v1||!v2) return null;
    const pct=Math.round((v2-v1)/v1*100);
    const good=inv?pct>0:pct<0;
    const col=good?C.bl:pct===0?C.gy:C.pk;
    return <span style={{background:col+"18",color:col,fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:100,fontFamily:"monospace"}}>{pct>0?"+":""}{pct}%</span>;
  };

  return(
    <div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14,marginBottom:22}}>
        {[[1,fs1],[2,fs2]].map(([p,fs])=>(
          <div key={p} style={{background:C.wh,borderRadius:14,padding:"18px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderTop:"4px solid "+(p===1?C.bl:C.or)}}>
            <div style={{fontSize:12,fontWeight:700,marginBottom:12,color:p===1?C.bl:C.or}}>Período {p}</div>
            <div style={{display:"flex",flexDirection:"column",gap:7}}>
              <UploadZone label="Campañas" icon="📊" desc="CSV campañas" status={fs.c} onFile={hf(p,"c",parseCamps)}/>
              <UploadZone label="Conjuntos" icon="🗂" desc="CSV conjuntos" status={fs.s} onFile={hf(p,"s",parseSets)}/>
              <UploadZone label="Anuncios" icon="🎨" desc="CSV anuncios" status={fs.a} onFile={hf(p,"a",parseAds)}/>
            </div>
          </div>
        ))}
      </div>

      {hasBoth&&(
        <div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(160px,1fr))",gap:11,marginBottom:18}}>
            {[
              ["Gasto","CLP "+fmtM(s1),"CLP "+fmtM(s2),s1,s2,false,C.bk],
              ["Leads",l1,l2,l1,l2,true,C.bl],
              ["CPL promedio","$"+fmt(c1),"$"+fmt(c2),c1,c2,false,C.pk],
            ].map(([label,v1,v2,n1,n2,inv,ac])=>(
              <div key={label} style={{background:C.wh,borderRadius:12,padding:"14px 13px",borderTop:"4px solid "+ac,boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
                <div style={{fontSize:9,color:C.gy,letterSpacing:"0.14em",textTransform:"uppercase",fontWeight:700,marginBottom:6}}>{label}</div>
                <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap",marginBottom:5}}>
                  <div><div style={{fontSize:9,color:C.bl,fontWeight:700,marginBottom:2}}>P1</div><div style={{fontSize:14,fontWeight:700}}>{v1}</div></div>
                  <div style={{fontSize:11,color:C.gy}}>→</div>
                  <div><div style={{fontSize:9,color:C.or,fontWeight:700,marginBottom:2}}>P2</div><div style={{fontSize:14,fontWeight:700}}>{v2}</div></div>
                </div>
                <Chg v1={n1} v2={n2} inv={inv}/>
              </div>
            ))}
          </div>

          <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
            <div style={{fontSize:13,fontWeight:700,marginBottom:16}}>Comparación por campaña</div>
            {p1.camps.map((c1c,i)=>{
              const c2c=p2.camps.find(c=>c.nombre===c1c.nombre);
              if(!c2c) return null;
              const cplChg=c1c.cpl>0?Math.round((c2c.cpl-c1c.cpl)/c1c.cpl*100):0;
              const leadsChg=c1c.leads>0?Math.round((c2c.leads-c1c.leads)/c1c.leads*100):0;
              const better=cplChg<-5, worse=cplChg>5;
              return(
                <div key={i} style={{background:better?C.bl+"08":worse?C.pk+"08":C.cr,borderRadius:9,padding:"11px 13px",marginBottom:7,border:"1px solid "+(better?C.bl+"20":worse?C.pk+"20":C.lg)}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:7,flexWrap:"wrap",gap:6}}>
                    <span style={{fontSize:11,fontWeight:700}}>{c1c.nombre.slice(0,45)}</span>
                    {better&&<Pill color={C.bl}>Mejoró</Pill>}
                    {worse&&<Pill color={C.pk}>Empeoró</Pill>}
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:9}}>
                    {[["CPL P1","$"+fmt(c1c.cpl),C.bk],["CPL P2","$"+fmt(c2c.cpl),C.bk],["CPL Δ",(cplChg>0?"+":"")+cplChg+"%",cplChg<0?C.bl:cplChg>0?C.pk:C.gy],["Leads Δ",(leadsChg>0?"+":"")+leadsChg+"%",leadsChg>0?C.bl:leadsChg<0?C.pk:C.gy]].map(([l,v,co])=>(
                      <div key={l}><div style={{fontSize:9,color:C.gy,fontWeight:700,textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:2}}>{l}</div><div style={{fontSize:13,fontWeight:700,color:co}}>{v}</div></div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {!hasBoth&&(p1.camps.length>0||p2.camps.length>0)&&(
        <div style={{background:C.bl+"10",border:"1px solid "+C.bl+"25",borderLeft:"4px solid "+C.bl,borderRadius:10,padding:"13px 16px"}}>
          <span style={{fontSize:13,color:C.dk}}>Carga los datos de ambos períodos para ver la comparación.</span>
        </div>
      )}
    </div>
  );
}

// ── MAIN APP ─────────────────────────────────────────────────
function App() {
  const [tab,setTab]=useState("upload");
  const [fs,setFs]=useState({c:"",s:"",a:""});
  const [data,setData]=useState({camps:[],sets:[],ads:[]});
  const [expanded,setExpanded]=useState(null);
  const [objF,setObjF]=useState({ov:"all",w:"all",adv:"all"});

  const hf=(key,parser)=>(rows,st)=>{
    setFs(f=>({...f,[key]:st}));
    if(st==="ok") setData(d=>({...d,[key==="c"?"camps":key==="s"?"sets":"ads"]:parser(rows)}));
  };

  const fCamps=useMemo(()=>objF.ov==="all"?data.camps:data.camps.filter(c=>c.objetivo===objF.ov),[data.camps,objF.ov]);
  const fWorst=useMemo(()=>objF.w==="all"?data.camps:data.camps.filter(c=>c.objetivo===objF.w),[data.camps,objF.w]);
  const fSets=useMemo(()=>objF.adv==="all"?data.sets:data.sets.filter(s=>s.objetivo===objF.adv),[data.sets,objF.adv]);
  const campObjs=useMemo(()=>[...new Set(data.camps.map(c=>c.objetivo))],[data.camps]);
  const setsObjs=useMemo(()=>[...new Set(data.sets.map(s=>s.objetivo))],[data.sets]);

  const tG=fCamps.reduce((a,c)=>a+c.gasto,0);
  const tL=fCamps.reduce((a,c)=>a+c.leads,0);
  const avg=tL>0?tG/tL:0;
  const cwl=fCamps.filter(c=>c.leads>0).sort((a,b)=>a.cpl-b.cpl);
  const best=cwl[0], worst=cwl[cwl.length-1];
  const critW=fWorst.filter(c=>c.leads>0&&c.cpl>avg*2);
  const fSetsWL=fSets.filter(s=>s.leads>0).sort((a,b)=>b.alcance-a.alcance);
  const avgSetCPL=fSetsWL.length?fSetsWL.reduce((a,s)=>a+s.cpl,0)/fSetsWL.length:0;
  const allLoaded=fs.c==="ok"||fs.s==="ok"||fs.a==="ok";

  const TABS=[
    {id:"upload",lbl:"📂 Importar"},
    {id:"ov",lbl:"Panorama"},
    {id:"analisis",lbl:"📈 Análisis"},
    {id:"reco",lbl:"⚡ 5 Recomendaciones"},
    {id:"worst",lbl:"Campañas críticas"},
    {id:"adv",lbl:"Adv+ vs Intereses"},
    {id:"comp",lbl:"⟷ Comparar períodos"},
  ];

  return(
    <div style={{minHeight:"100vh",background:C.cr,paddingBottom:80}}>
      <div style={{background:C.bk,padding:"0 32px",position:"sticky",top:0,zIndex:100}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",paddingTop:16,flexWrap:"wrap",gap:10}}>
          <div style={{display:"flex",alignItems:"center",gap:13}}>
            <span style={{fontSize:20,fontWeight:700,color:"#fff",letterSpacing:"0.15em"}}>MÁS</span>
            <div style={{width:1,height:24,background:"#2a2a2a"}}/>
            <div>
              <div style={{fontSize:10,color:"#555",letterSpacing:"0.18em",textTransform:"uppercase",fontWeight:700}}>Meta Ads Dashboard</div>
              {allLoaded&&<div style={{fontSize:10,color:"#444",marginTop:1}}>{data.camps.length} campañas · {data.sets.length} conjuntos · {data.ads.length} anuncios</div>}
            </div>
          </div>
          {allLoaded&&campObjs.length>1&&(
            <div style={{display:"flex",gap:5,flexWrap:"wrap"}}>
              {campObjs.map(o=>{const m=OBJ[o]||OBJ.otro;return(
                <div key={o} style={{display:"flex",alignItems:"center",gap:4,background:m.color+"20",borderRadius:100,padding:"3px 9px"}}>
                  <div style={{width:5,height:5,borderRadius:"50%",background:m.color}}/>
                  <span style={{fontSize:9,color:m.color,fontWeight:700}}>{m.icon} {data.camps.filter(c=>c.objetivo===o).length}</span>
                </div>);}
              )}
            </div>
          )}
        </div>
        <div style={{display:"flex",height:3,marginTop:13}}>
          <div style={{flex:1,background:C.pk}}/><div style={{flex:1,background:C.bl}}/><div style={{flex:1,background:C.or}}/>
        </div>
        <div style={{display:"flex",flexWrap:"nowrap",overflowX:"auto"}}>
          {TABS.map(t=><button key={t.id} onClick={()=>setTab(t.id)} style={{background:"transparent",color:tab===t.id?C.wh:"#555",border:"none",borderBottom:"3px solid "+(tab===t.id?C.pk:"transparent"),padding:"10px 13px",fontSize:11,fontWeight:600,letterSpacing:"0.03em",whiteSpace:"nowrap"}}>{t.lbl}</button>)}
        </div>
      </div>

      <div style={{padding:"26px 32px"}}>

        {tab==="upload"&&(
          <div style={{maxWidth:820,margin:"0 auto"}}>
            <h2 style={{fontSize:19,fontWeight:700,marginBottom:7}}>Importar reportes</h2>
            <p style={{fontSize:13,color:C.gy,lineHeight:1.7,marginBottom:20}}>Exporta los reportes desde Meta Ads Manager en CSV. El dashboard detecta automáticamente el objetivo de cada campaña y te permite filtrar por tipo.</p>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(200px,1fr))",gap:11,marginBottom:22}}>
              <UploadZone label="Campañas" icon="📊" desc="Vista Campañas · Exportar → CSV" status={fs.c} onFile={hf("c",parseCamps)}/>
              <UploadZone label="Conjuntos de anuncios" icon="🗂" desc="Vista Conjuntos · Exportar → CSV" status={fs.s} onFile={hf("s",parseSets)}/>
              <UploadZone label="Anuncios" icon="🎨" desc="Vista Anuncios · Exportar → CSV" status={fs.a} onFile={hf("a",parseAds)}/>
            </div>
            {data.camps.length>0&&(
              <div style={{background:C.wh,borderRadius:14,padding:"18px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
                <div style={{fontSize:12,fontWeight:700,marginBottom:13}}>Objetivos detectados</div>
                <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(170px,1fr))",gap:9}}>
                  {campObjs.map(o=>{const m=OBJ[o]||OBJ.otro;const cs=data.camps.filter(c=>c.objetivo===o);return(
                    <div key={o} style={{background:C.cr,borderRadius:9,padding:"13px",borderLeft:"4px solid "+m.color}}>
                      <div style={{fontSize:15,marginBottom:4}}>{m.icon}</div>
                      <div style={{fontSize:11,fontWeight:700,color:m.color,marginBottom:5}}>{m.label}</div>
                      <div style={{fontSize:10,color:C.gy}}>{cs.length} campañas · {cs.reduce((a,c)=>a+c.leads,0)} leads · CLP {fmt(cs.reduce((a,c)=>a+c.gasto,0))}</div>
                    </div>);}
                  )}
                </div>
              </div>
            )}
            {allLoaded&&(
              <div style={{background:C.bk,borderRadius:12,padding:"13px 18px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:12}}>
                <div><div style={{fontSize:12,fontWeight:700,color:C.wh}}>Datos cargados</div><div style={{fontSize:10,color:"#555",marginTop:2}}>{data.camps.length} campañas · {data.sets.length} conjuntos · {data.ads.length} anuncios</div></div>
                <button onClick={()=>setTab("ov")} style={{background:C.pk,color:C.wh,border:"none",borderRadius:8,padding:"8px 18px",fontSize:12,fontWeight:700}}>Ver Panorama →</button>
              </div>
            )}
          </div>
        )}

        {tab==="ov"&&(
          data.camps.length===0?<EmptyState onGo={()=>setTab("upload")}/>:(
            <div>
              <ObjFilter objs={campObjs} active={objF.ov} onChange={v=>setObjF(f=>({...f,ov:v}))}/>
              <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(138px,1fr))",gap:11,marginBottom:22}}>
                <StatCard label="Gasto total" value={"CLP "+fmtM(tG)} accent={C.bk}/>
                <StatCard label="Total leads" value={tL} accent={C.bl}/>
                <StatCard label="CPL promedio" value={"$"+fmt(avg)} accent={C.bl}/>
                <StatCard label="Mejor CPL" value={best?"$"+fmt(best.cpl):"—"} sub={best?.nombre?.slice(0,20)} accent={C.bl}/>
                <StatCard label="Peor CPL" value={worst?"$"+fmt(worst.cpl):"—"} sub={worst?.nombre?.slice(0,20)} accent={C.pk}/>
                <StatCard label="Campañas críticas" value={critW.length} sub="CPL > 2x promedio" accent={critW.length>0?C.or:C.bl}/>
              </div>
              <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16,flexWrap:"wrap",gap:10}}>
                  <div><div style={{fontSize:13,fontWeight:700}}>Ranking por CPL</div><div style={{fontSize:11,color:C.gy,marginTop:2}}>CPL promedio: ${fmt(avg)}</div></div>
                  <div style={{display:"flex",gap:10}}>{[[C.pk,"Crítico"],[C.or,"Atención"],[C.bl,"Óptimo"]].map(([col,lbl])=><div key={lbl} style={{display:"flex",alignItems:"center",gap:5}}><div style={{width:7,height:7,borderRadius:"50%",background:col}}/><span style={{fontSize:10,color:C.gy,fontWeight:600}}>{lbl}</span></div>)}</div>
                </div>
                {cwl.map((c,i)=>{
                  const m=OBJ[c.objetivo]||OBJ.otro;
                  const col=c.cpl>avg*2?C.pk:c.cpl>avg*1.5?C.or:c.cpl<avg*.7?C.bl:C.gy;
                  const pct=cwl.length>0?(c.cpl/cwl[cwl.length-1].cpl)*100:0;
                  return(
                    <div key={i} style={{display:"grid",gridTemplateColumns:"22px 15px 1fr 1fr",gap:10,alignItems:"center",marginBottom:11}}>
                      <div style={{width:20,height:20,borderRadius:5,background:c.cpl>avg*2?C.pk:c.cpl<avg*.7?C.bl:C.lg,display:"flex",alignItems:"center",justifyContent:"center",fontSize:9,fontWeight:700,color:c.cpl>avg*2||c.cpl<avg*.7?C.wh:C.gy}}>{i+1}</div>
                      <span title={m.label} style={{fontSize:12}}>{m.icon}</span>
                      <div><div style={{fontSize:11,fontWeight:600,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{c.nombre}</div><div style={{fontSize:9,color:C.gy,marginTop:1}}>{c.leads} leads · frec. {c.frecuencia.toFixed(1)}x</div></div>
                      <div style={{display:"flex",alignItems:"center",gap:10}}>
                        <div style={{flex:1,height:3,background:C.lg,borderRadius:2}}><div style={{width:pct+"%",height:"100%",background:col,borderRadius:2}}/></div>
                        <span style={{fontSize:12,fontWeight:700,color:col,minWidth:80,textAlign:"right",fontFamily:"monospace"}}>${fmt(c.cpl)}</span>
                      </div>
                    </div>
                  );
                })}
              </div>
              {best&&<div style={{background:C.bl+"10",border:"1.5px solid "+C.bl+"25",borderLeft:"4px solid "+C.bl,borderRadius:10,padding:"13px 17px"}}><div style={{fontSize:10,color:C.bl,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase",marginBottom:6}}>💡 Insight</div><p style={{margin:0,fontSize:12,color:C.dk,lineHeight:1.7}}><strong>{best.nombre}</strong> es la más eficiente con <strong style={{color:C.bl}}>${fmt(best.cpl)}/lead</strong>{worst&&" — "+Math.round(worst.cpl/best.cpl)+"x más eficiente que "+worst.nombre.slice(0,30)}{campObjs.length>1&&objF.ov==="all"&&<span style={{color:C.or}}> Filtra por objetivo para comparaciones justas.</span>}</p></div>}
            </div>
          )
        )}

        {tab==="analisis"&&(data.camps.length===0?<EmptyState onGo={()=>setTab("upload")}/>:<AnalisisTab campaigns={data.camps} adSets={data.sets} ads={data.ads}/>)}

        {tab==="reco"&&(data.camps.length===0?<EmptyState onGo={()=>setTab("upload")}/>:<RecoTab campaigns={data.camps} adSets={data.sets} ads={data.ads}/>)}

        {tab==="worst"&&(
          data.camps.length===0?<EmptyState onGo={()=>setTab("upload")}/>:(
            <div>
              <ObjFilter objs={campObjs} active={objF.w} onChange={v=>setObjF(f=>({...f,w:v}))}/>
              {critW.length===0?(
                <div style={{background:C.wh,borderRadius:14,padding:"48px 32px",textAlign:"center",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}><div style={{fontSize:32,marginBottom:12}}>🎉</div><div style={{fontSize:16,fontWeight:700}}>No hay campañas críticas</div></div>
              ):(
                <div>
                  <div style={{background:C.wh,borderRadius:12,padding:"13px 17px",marginBottom:16,display:"flex",gap:18,flexWrap:"wrap",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderLeft:"4px solid "+C.pk}}>
                    {[["CPL promedio","$"+fmt(avg),C.bk],["Críticas",critW.length,C.pk],["Gasto en críticas","CLP "+fmt(critW.reduce((a,c)=>a+c.gasto,0)),C.pk]].map(([l,v,co])=><div key={l}><div style={{fontSize:9,color:C.gy,fontWeight:700,letterSpacing:"0.12em",textTransform:"uppercase"}}>{l}</div><div style={{fontSize:17,fontWeight:700,color:co,marginTop:3}}>{v}</div></div>)}
                  </div>
                  {critW.map((c,idx)=>{
                    const ac=c.cpl>avg*4?C.pk:C.or;
                    return(
                      <div key={idx} style={{background:C.wh,borderRadius:14,marginBottom:9,overflow:"hidden",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderTop:"4px solid "+ac}}>
                        <div onClick={()=>setExpanded(expanded===idx?null:idx)} style={{padding:"14px 18px",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:9}}>
                          <div style={{display:"flex",alignItems:"center",gap:11}}>
                            <div style={{background:ac,borderRadius:7,padding:"4px 10px"}}><span style={{fontSize:11,fontWeight:700,color:C.wh,fontFamily:"monospace"}}>${fmt(c.cpl)}</span></div>
                            <div><div style={{fontSize:12,fontWeight:700}}>{c.nombre}</div><div style={{fontSize:10,color:C.gy,marginTop:1}}>{c.leads} leads · frec. {c.frecuencia.toFixed(1)}x · {(c.cpl/avg).toFixed(1)}x el promedio</div></div>
                          </div>
                          <span style={{fontSize:11,color:C.gy}}>{expanded===idx?"▲":"▼"}</span>
                        </div>
                        {expanded===idx&&(
                          <div style={{padding:"0 18px 16px",borderTop:"1px solid "+C.lg}}>
                            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(95px,1fr))",gap:8,marginTop:13,marginBottom:13}}>
                              {[["Leads",c.leads,false],["Gasto","CLP "+fmt(c.gasto),false],["Frecuencia",c.frecuencia.toFixed(1)+"x",c.frecuencia>3],["CPR vs avg",(c.cpl/avg).toFixed(1)+"x",true],["Alcance",fmt(c.alcance),c.alcance<15000]].map(([l,v,al])=>(
                                <div key={l} style={{background:al?C.pk+"08":C.cr,border:"1px solid "+(al?C.pk+"25":C.lg),borderRadius:8,padding:"9px 10px"}}>
                                  <div style={{fontSize:9,color:C.gy,fontWeight:700,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:3}}>{l}</div>
                                  <div style={{fontSize:15,fontWeight:700,color:al?C.pk:C.bk}}>{v}</div>
                                </div>
                              ))}
                            </div>
                            <div style={{background:C.cr,borderRadius:8,padding:"11px 13px"}}>
                              <div style={{fontSize:9,fontWeight:700,color:C.bk,marginBottom:7,textTransform:"uppercase",letterSpacing:"0.08em"}}>Acciones recomendadas</div>
                              {[c.frecuencia>4&&"⛔ Frecuencia crítica — renovar creativos urgente",c.alcance<10000&&"🗺️ Alcance muy pequeño — ampliar targeting",c.cpl>avg*4&&"💰 Pausar y reasignar a "+(best?.nombre?.slice(0,25)||"mejor campaña"),"🎯 Verificar intereses Adv+ como sugerencias","📝 Formulario — máximo 3 campos"].filter(Boolean).map((a,j)=>(
                                <div key={j} style={{fontSize:11,color:C.dk,lineHeight:1.6,marginBottom:5,display:"flex",gap:7}}><span>{a.slice(0,2)}</span><span>{a.slice(2)}</span></div>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              )}
            </div>
          )
        )}

        {tab==="adv"&&(
          <div>
            <div style={{background:C.bk,borderRadius:14,padding:"18px 22px",marginBottom:18,color:C.wh}}>
              <div style={{fontSize:10,color:"#555",fontWeight:700,letterSpacing:"0.15em",textTransform:"uppercase",marginBottom:9}}>Adv+ vs. Intereses</div>
              <p style={{margin:"0 0 5px",fontSize:14,fontWeight:700}}>El problema no es la herramienta — es el tamaño de la audiencia.</p>
              <p style={{margin:0,fontSize:12,color:"#aaa",lineHeight:1.6}}>Audiencias +30k → CPR óptimo. Audiencias -15k → CPR crítico.</p>
            </div>
            {data.sets.length>0&&(
              <div>
                <ObjFilter objs={setsObjs} active={objF.adv} onChange={v=>setObjF(f=>({...f,adv:v}))}/>
                {fSetsWL.length>0&&(
                  <div style={{background:C.wh,borderRadius:14,padding:"18px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
                    <div style={{fontSize:12,fontWeight:700,marginBottom:3}}>Alcance vs CPL por conjunto</div>
                    <div style={{fontSize:11,color:C.gy,marginBottom:15}}>Barra = audiencia · color = CPL relativo al promedio</div>
                    {fSetsWL.map((s,i)=>{
                      const maxA=fSetsWL[0]?.alcance||1;
                      const p=Math.min((s.alcance/maxA)*100,100);
                      const col=s.cpl>avgSetCPL*2?C.pk:s.cpl>avgSetCPL*1.3?C.or:C.bl;
                      return(
                        <div key={i} style={{display:"grid",gridTemplateColumns:"130px 1fr 80px",gap:10,alignItems:"center",marginBottom:8}}>
                          <div style={{fontSize:10,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",color:s.cpl<avgSetCPL?C.bk:C.gy,fontWeight:s.cpl<avgSetCPL?600:400}}>{s.nombre}</div>
                          <div><div style={{height:5,background:C.lg,borderRadius:3}}><div style={{width:p+"%",height:"100%",background:col,borderRadius:3}}/></div><div style={{fontSize:9,color:C.gy,marginTop:2}}>{fmt(s.alcance)} personas</div></div>
                          <div style={{fontSize:11,fontWeight:700,color:col,textAlign:"right",fontFamily:"monospace"}}>${fmt(s.cpl)}</div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            )}
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(210px,1fr))",gap:12}}>
              {[
                {t:"✅ Sigue usando Adv+",co:C.bl,ps:["Funciona bien con audiencias >30k","No cambies lo que ya genera buen CPR","Usa el gráfico para detectar dónde hay problemas de tamaño"]},
                {t:"⚙ Intereses en Adv+",co:C.or,ps:["Agrégalos como SUGERENCIAS, no restricciones","Meta puede salir si encuentra mejores audiencias","Úsalos para orientar, no para limitar"]},
                {t:"🚫 Lo que NO hacer",co:C.pk,ps:["No restringir conjuntos con alcance < 15k","No segmentar por edad específica en nichos pequeños","No crear conjuntos sin revisar tamaño estimado"]},
              ].map((card,i)=>(
                <div key={i} style={{background:C.wh,borderRadius:12,padding:"16px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderTop:"4px solid "+card.co}}>
                  <div style={{fontSize:11,fontWeight:700,color:card.co,marginBottom:11}}>{card.t}</div>
                  {card.ps.map((p,j)=><div key={j} style={{display:"flex",gap:7,alignItems:"flex-start",marginBottom:7}}><div style={{width:4,height:4,borderRadius:"50%",background:card.co,marginTop:6,flexShrink:0}}/><div style={{fontSize:11,color:C.dk,lineHeight:1.5}}>{p}</div></div>)}
                </div>
              ))}
            </div>
          </div>
        )}

        {tab==="comp"&&<ComparTab/>}

      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);

</script>
</body>
</html>
