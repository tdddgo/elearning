      </div>
      {top5.map((r,i)=>(
        <div key={i} style={{background:C.wh,borderRadius:16,overflow:"hidden",boxShadow:"0 2px 8px rgba(0,0,0,.07)",border:"1px solid "+C.lg,marginBottom:12}}>
          <div style={{display:"flex",alignItems:"stretch"}}>
