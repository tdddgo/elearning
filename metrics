  });

  const generics=[
    {color:C.or,icon:"🤖",urg:"PRÓXIMA SEMANA",tipo:"optimización",titulo:"Crear reglas automáticas de pausa por CPL",porque:"Sin reglas, una campaña puede disparar el CPL durante el finde sin que nadie lo note hasta el lunes.",accion:"Ads Manager → Reglas automáticas → si CPL > 2x promedio por 2 días → pausar y notificar.",impacto:"Evita quemar presupuesto en períodos de bajo rendimiento",items:[]},
    {color:C.bl,icon:"👥",urg:"PRÓXIMA SEMANA",tipo:"audiencia",titulo:"Crear audiencias lookalike de tus mejores leads",porque:"Con leads pasados, Meta puede encontrar perfiles similares. Las lookalike 1–3% son más eficientes que intereses.",accion:"Subir lista de leads (mín. 100) → Audiencias → Lookalike 1%, 2%, 3% → testear en conjuntos separados.",impacto:"Las lookalike suelen tener CPL 20–40% menor que audiencias de intereses",items:[]},
    {color:C.bl,icon:"🧪",urg:"PRÓXIMA SEMANA",tipo:"creativos",titulo:"Implementar test A/B en tu mejor campaña",porque:"Sin comparativa sistemática, las decisiones son a ciegas. Un A/B bien configurado indica qué elemento convierte más.",accion:"Duplicar conjunto, cambiar solo una variable. Dejar correr 7 días con igual presupuesto. Pausar el perdedor.",impacto:"Los mejores creativos suelen tener 2–3x el rendimiento del promedio",items:[]},
  ];

  const top5=[...signals].sort((a,b)=>b.score-a.score).slice(0,5);
  while(top5.length<5) top5.push(generics[top5.length-signals.length]||generics[0]);
  const tipoCol={presupuesto:C.pk,creativos:C.or,audiencia:C.or,formulario:C.bl,optimización:C.or};

  return(
    <div>
