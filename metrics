// ── 5 RECOMENDACIONES ───────────────────────────────────────
function RecoTab({campaigns,adSets,ads}) {
  const tG=campaigns.reduce((a,c)=>a+c.gasto,0);
  const tL=campaigns.reduce((a,c)=>a+c.leads,0);
  const avg=tL>0?tG/tL:0;
  const cwl=campaigns.filter(c=>c.leads>0).sort((a,b)=>a.cpl-b.cpl);
  const best=cwl[0];
  const signals=[];

  const crit=cwl.filter(c=>c.cpl>avg*2).sort((a,b)=>b.gasto-a.gasto);
  const wG=crit.reduce((a,c)=>a+c.gasto,0);
  const ext=best?Math.round(wG*.6/best.cpl):0;
  if(crit.length>0) signals.push({score:wG,color:C.pk,icon:"⛔",urg:"HOY",tipo:"presupuesto",
    titulo:crit.length===1?"Recortar presupuesto de: "+crit[0].nombre.slice(0,35):"Recortar "+crit.length+" campañas con CPL crítico",
    porque:"Consumen CLP "+fmt(wG)+" ("+Math.round(wG/tG*100)+"% del total) y generan solo "+Math.round(crit.reduce((a,c)=>a+c.leads,0)/tL*100)+"% de los leads. CPL promedio "+Math.round(crit.reduce((a,c)=>a+c.cpl,0)/crit.length/avg)+"x el promedio de la cuenta.",
    accion:"Recortar 60–70% a: "+crit.slice(0,3).map(c=>c.nombre.slice(0,25)).join(", ")+". Redirigir a "+(best?.nombre?.slice(0,30)||"mejor campaña")+".",
    impacto:"~"+ext+" leads adicionales sin aumentar el presupuesto total",
    items:crit.slice(0,3).map(c=>c.nombre.slice(0,45)+" — CPL $"+fmt(c.cpl)),
  });

  const nl=campaigns.filter(c=>c.gasto>5000&&c.leads===0);
  if(nl.length>0) signals.push({score:nl.reduce((a,c)=>a+c.gasto,0)*1.5,color:C.pk,icon:"🗑️",urg:"HOY",tipo:"presupuesto",
    titulo:"Pausar "+nl.length+" campaña(s) con gasto y cero resultados",
    porque:"Gastaron CLP "+fmt(nl.reduce((a,c)=>a+c.gasto,0))+" sin generar ningún lead. El dinero se quema sin retorno posible.",
    accion:"Pausar inmediatamente y revisar configuración del píxel y evento de conversión.",
    impacto:"Recupera CLP "+fmt(nl.reduce((a,c)=>a+c.gasto,0))+" para reasignar",
    items:nl.slice(0,3).map(c=>c.nombre.slice(0,45)+" — "+fmt(c.gasto)+" CLP, 0 leads"),
  });

  const sat=campaigns.filter(c=>c.frecuencia>4&&c.leads>0).sort((a,b)=>b.frecuencia-a.frecuencia);
  if(sat.length>0) signals.push({score:sat.reduce((a,c)=>a+c.gasto,0)*.8,color:C.or,icon:"🎨",urg:"ESTA SEMANA",tipo:"creativos",
    titulo:"Renovar creativos en "+sat.length+" campaña(s) saturadas",
    porque:"Frecuencia "+sat.map(c=>c.frecuencia.toFixed(1)+"x").join(", ")+". Sobre 4x la audiencia deja de responder — el CPL sube aunque el targeting sea correcto.",
    accion:"2–3 creativos con propuesta de valor distinta. Meta: bajar frecuencia <2.5x en 2 semanas.",
    impacto:"Puede reducir CPL 30–50% sin cambiar presupuesto ni audiencia",
    items:sat.slice(0,3).map(c=>c.nombre.slice(0,45)+" — frec. "+c.frecuencia.toFixed(1)+"x"),
  });

  const sml=campaigns.filter(c=>c.alcance>0&&c.alcance<12000&&c.leads>0);
  if(sml.length>0) signals.push({score:sml.reduce((a,c)=>a+c.gasto,0)*1.2,color:C.or,icon:"🗺️",urg:"ESTA SEMANA",tipo:"audiencia",
    titulo:"Ampliar audiencia en "+sml.length+" campaña(s) con alcance microscópico",
    porque:"Adv+ necesita mín. 50k personas. Con "+sml.map(c=>fmt(c.alcance)).join(", ")+" personas el algoritmo no puede aprender.",
    accion:"Ampliar cobertura geográfica, rango etario 25–55 años, e intereses en Adv+ como sugerencias.",
    impacto:"Con audiencia >50k el CPL puede bajar hasta 60%",
    items:sml.slice(0,3).map(s=>s.nombre.slice(0,45)+" — "+fmt(s.alcance)+" personas"),
  });

  const fn=ads.filter(a=>/encima|above/i.test(a.calidad)&&/abajo|below/i.test(a.conversion)&&a.leads>0);
  if(fn.length>0) signals.push({score:fn.reduce((a,x)=>a+x.gasto,0)*.9,color:C.bl,icon:"📝",urg:"ESTA SEMANA",tipo:"formulario",
    titulo:"Simplificar formularios — "+fn.length+" anuncio(s) pierden leads post-clic",
    porque:"Calidad encima del promedio + conversión abajo = el creativo atrae pero el formulario repele.",
    accion:"Máximo 3 campos. Pantalla de confirmación. Testear landing externa vs. formulario nativo.",
    impacto:"Formularios simples pueden duplicar la tasa de conversión",
    items:fn.slice(0,3).map(a=>a.nombre.slice(0,45)+" — CPL $"+fmt(a.cpl)),
  });

  const under=cwl.filter(c=>c.cpl<avg*.6&&tG>0&&c.gasto/tG<0.1);
  if(under.length>0) signals.push({score:under.reduce((a,c)=>a+(avg-c.cpl)*c.leads,0)*.7,color:C.bl,icon:"🚀",urg:"ESTA SEMANA",tipo:"presupuesto",
    titulo:"Escalar "+under.length+" campaña(s) subfinanciadas con CPL óptimo",
