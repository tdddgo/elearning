<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>MÁS · Meta Ads Dashboard</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{background:#f7f5f0;font-family:"Montserrat",sans-serif}
    button{font-family:inherit;cursor:pointer}
    .dz{border:2px dashed #e8e8e8;border-radius:14px;padding:24px 14px;text-align:center;transition:all .2s;background:#fff;cursor:pointer}
    .dz.drag{border-color:#29ABE2;background:#29ABE210}
    .dz.done{border-color:#29ABE2;border-style:solid}
    .dz.err{border-color:#E91E8C}
    input[type=file]{display:none}
    ::-webkit-scrollbar{width:4px;height:4px}
    ::-webkit-scrollbar-thumb{background:#ccc;border-radius:2px}
  </style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const {useState,useRef,useMemo} = React;
const LOGO = null;
const C = {bk:"#0a0a0a",wh:"#fff",cr:"#f7f5f0",pk:"#E91E8C",bl:"#29ABE2",or:"#F7941D",gy:"#888",lg:"#e8e8e8",dk:"#333"};

function parseCSV(text) {
  const lines = text.split(/
?
/).filter(l => l.trim());
  if (lines.length < 2) return [];
  const hdrs = lines[0].split(",").map(h => h.replace(/^"|"$/g,"").trim());
  return lines.slice(1).map(line => {
    const vals = []; let cur = "", inQ = false;
    for (let c of line) {
      if (c === '"') inQ = !inQ;
      else if (c === ',' && !inQ) { vals.push(cur); cur = ""; }
      else cur += c;
    }
    vals.push(cur);
    const obj = {}; hdrs.forEach((h,i) => { obj[h] = (vals[i]||"").trim(); }); return obj;
  });
}

function detectObj(r) {
  const ind = (r["Indicador de resultado"]||"").toLowerCase();
  const nm = (r["Nombre de la campaña"]||r["Nombre del conjunto de anuncios"]||r["Nombre del anuncio"]||"").toLowerCase();
  if (/leadgen|lead/.test(ind)) return "leads";
  if (/landing|visit|destino/.test(ind)) return "visitas";
  if (/click|clic/.test(ind)) return "clics";
  if (/conv/.test(nm)) return "leads";
  return "otro";
}

function parseCamps(rows) {
  return rows.filter(r=>r["Nombre de la campaña"])
    .map(r=>({nombre:r["Nombre de la campaña"],leads:+r["Resultados"]||0,cpl:+r["Costo por resultados"]||0,
      gasto:+r["Importe gastado (CLP)"]||0,alcance:+r["Alcance"]||0,frecuencia:+r["Frecuencia"]||0,objetivo:detectObj(r)}))
    .filter(r=>r.gasto>0).sort((a,b)=>b.cpl-a.cpl);
}
function parseSets(rows) {
  return rows.filter(r=>r["Nombre del conjunto de anuncios"])
    .map(r=>({nombre:r["Nombre del conjunto de anuncios"],leads:+r["Resultados"]||0,cpl:+r["Costo por resultados"]||0,
      gasto:+r["Importe gastado (CLP)"]||0,alcance:+r["Alcance"]||0,frecuencia:+r["Frecuencia"]||0,objetivo:detectObj(r)}))
    .filter(r=>r.gasto>0);
}
function parseAds(rows) {
  return rows.filter(r=>r["Nombre del anuncio"])
    .map(r=>({nombre:r["Nombre del anuncio"],leads:+r["Resultados"]||0,cpl:+r["Costo por resultados"]||0,
      gasto:+r["Importe gastado (CLP)"]||0,alcance:+r["Alcance"]||0,
      conjunto:r["Nombre del conjunto de anuncios"]||"",
      calidad:r["Clasificación de calidad"]||"-",conversion:r["Clasificación del porcentaje de conversiones"]||"-",
      objetivo:detectObj(r)}))
    .filter(r=>r.gasto>0);
}

const fmt = n => Math.round(n).toLocaleString("es-CL");
const fmtM = n => (n/1000000).toFixed(2)+"M";
const eff = c => c.gasto>0 ? c.leads/(c.gasto/1000) : 0;
const OBJ = {
  leads:{icon:"📋",label:"Formularios/Leads",color:C.pk},
  visitas:{icon:"🌐",label:"Visitas a página",color:C.bl},
  clics:{icon:"🖱",label:"Clics en enlace",color:C.or},
  otro:{icon:"📌",label:"Otro objetivo",color:C.gy},
};

const Pill = ({children,color}) => (
  <span style={{background:color+"18",color,fontSize:9,fontWeight:700,letterSpacing:"0.1em",padding:"3px 9px",borderRadius:100,textTransform:"uppercase"}}>{children}</span>
);
const SBadge = ({val}) => {
  if (!val||val==="-") return <span style={{color:"#ccc",fontSize:11}}>—</span>;
  const up=/encima|above/i.test(val), dn=/abajo|below/i.test(val);
  const col=up?C.bl:dn?C.pk:C.or;
  return <span style={{background:col+"18",color:col,fontSize:10,fontWeight:700,padding:"3px 8px",borderRadius:100,fontFamily:"monospace"}}>{up?"↑":dn?"↓":"→"} {up?"Encima":dn?(val.includes("35")?"-35%":"-20%"):"Promedio"}</span>;
};
const EmptyState = ({onGo,msg}) => (
  <div style={{background:C.wh,borderRadius:14,padding:"48px 32px",textAlign:"center",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
    <div style={{fontSize:32,marginBottom:12}}>📂</div>
    <div style={{fontSize:16,fontWeight:700,marginBottom:8}}>Sin datos cargados</div>
    <div style={{fontSize:13,color:C.gy,marginBottom:20}}>{msg||"Importa tus reportes de Meta Ads."}</div>
    <button onClick={onGo} style={{background:C.bk,color:C.wh,border:"none",borderRadius:8,padding:"10px 22px",fontSize:13,fontWeight:700}}>Ir a Importar →</button>
  </div>
);
const StatCard = ({label,value,sub,accent}) => (
  <div style={{background:C.wh,borderRadius:12,padding:"15px 13px",borderTop:"4px solid "+(accent||C.bk),boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
    <div style={{fontSize:9,color:C.gy,letterSpacing:"0.14em",textTransform:"uppercase",fontWeight:700,marginBottom:6}}>{label}</div>
    <div style={{fontSize:19,fontWeight:700,color:(accent&&accent!==C.bk)?accent:C.bk}}>{value}</div>
    {sub&&<div style={{fontSize:9,color:C.gy,marginTop:3,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{sub}</div>}
  </div>
);

function UploadZone({label,icon,desc,status,onFile}) {
  const [drag,setDrag]=useState(false); const ref=useRef();
  const cls=status==="ok"?"done":status==="err"?"err":drag?"drag":"";
  const handle = file => {
    if (!file||!file.name.endsWith(".csv")) {onFile(null,"err"); return;}
    const reader=new FileReader();
    reader.onload=e=>{try{onFile(parseCSV(e.target.result),"ok")}catch{onFile(null,"err")}};
    reader.onerror=()=>onFile(null,"err"); reader.readAsText(file);
  };
  return (
    <div className={"dz "+cls} onDragOver={e=>{e.preventDefault();setDrag(true)}} onDragLeave={()=>setDrag(false)}
      onDrop={e=>{e.preventDefault();setDrag(false);handle(e.dataTransfer.files[0])}} onClick={()=>ref.current.click()}>
      <input ref={ref} type="file" accept=".csv" onChange={e=>handle(e.target.files[0])}/>
      <div style={{fontSize:22,marginBottom:6}}>{status==="ok"?"✅":status==="err"?"❌":icon}</div>
      <div style={{fontSize:12,fontWeight:700,color:status==="ok"?C.bl:C.bk,marginBottom:3}}>{label}</div>
      <div style={{fontSize:11,color:C.gy,lineHeight:1.4}}>{status==="ok"?"Cargado · clic para reemplazar":desc}</div>
    </div>
  );
}

function ObjFilter({objs,active,onChange}) {
  if (objs.length<=1) return null;
  return (
    <div style={{display:"flex",gap:8,flexWrap:"wrap",marginBottom:18}}>
      <button onClick={()=>onChange("all")} style={{background:active==="all"?C.bk:"transparent",color:active==="all"?C.wh:C.gy,border:"1.5px solid "+(active==="all"?C.bk:C.lg),borderRadius:100,padding:"6px 14px",fontSize:12,fontWeight:600}}>Todos</button>
      {objs.map(o=>{const m=OBJ[o]||OBJ.otro;const act=active===o;return(
        <button key={o} onClick={()=>onChange(o)} style={{background:act?m.color:"transparent",color:act?C.wh:C.gy,border:"1.5px solid "+(act?m.color:C.lg),borderRadius:100,padding:"6px 14px",fontSize:12,fontWeight:600,display:"flex",alignItems:"center",gap:5}}>
          <span style={{fontSize:13}}>{m.icon}</span>{m.label}
        </button>);}
      )}
    </div>
  );
}

function BarChart({data,valueKey,labelKey,height}) {
  const max = Math.max(...data.map(d=>d[valueKey]),1);
  const h = height||160;
  return (
    <div style={{display:"flex",alignItems:"flex-end",gap:5,height:h,padding:"0 2px"}}>
      {data.map((d,i)=>{
        const pct=(d[valueKey]/max)*100;
        const col=d[valueKey]===max?C.pk:d[valueKey]<max*0.4?C.bl:C.or;
        return (
          <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"flex-end",gap:3}}>
            <div style={{fontSize:8,color:col,fontWeight:700,fontFamily:"monospace",textAlign:"center"}}>{"$"+fmt(d[valueKey])}</div>
            <div style={{width:"100%",background:col,borderRadius:"3px 3px 0 0",height:pct+"%",minHeight:2}}/>
            <div style={{fontSize:8,color:C.gy,textAlign:"center",lineHeight:1.2,wordBreak:"break-word",maxWidth:45}}>{(""+d[labelKey]).slice(0,16)}</div>
          </div>
        );
      })}
    </div>
  );
}

// ── ANÁLISIS ENGINE ─────────────────────────────────────────
function AnalisisTab({campaigns,adSets,ads}) {
  const [sec,setSec]=useState("resumen");
  const [objF,setObjF]=useState("all");
  const camps = objF==="all"?campaigns:campaigns.filter(c=>c.objetivo===objF);
  const objs = useMemo(()=>[...new Set(campaigns.map(c=>c.objetivo))],[campaigns]);
  const tG=camps.reduce((a,c)=>a+c.gasto,0);
  const tL=camps.reduce((a,c)=>a+c.leads,0);
  const avg=tL>0?tG/tL:0;
  const cwl=camps.filter(c=>c.leads>0).sort((a,b)=>a.cpl-b.cpl);
  const best=cwl[0], worst=cwl[cwl.length-1];
  const criticals=cwl.filter(c=>c.cpl>avg*2);
  const noLeads=camps.filter(c=>c.gasto>5000&&c.leads===0);
  const saturated=camps.filter(c=>c.frecuencia>4&&c.leads>0);
  const smallAud=camps.filter(c=>c.alcance>0&&c.alcance<12000&&c.leads>0);
  const funnelAds=ads.filter(a=>/encima|above/i.test(a.calidad)&&/abajo|below/i.test(a.conversion)&&a.leads>0);
  const topAds=[...ads].filter(a=>a.leads>=2).sort((a,b)=>a.cpl-b.cpl).slice(0,8);
  const worstAds=[...ads].filter(a=>a.leads>0).sort((a,b)=>b.cpl-a.cpl).slice(0,6);
  const setsWL=[...adSets].filter(a=>a.leads>0).sort((a,b)=>b.alcance-a.alcance).slice(0,12);
  const avgSetCPL=setsWL.length?setsWL.reduce((a,s)=>a+s.cpl,0)/setsWL.length:0;
  const effRank=[...cwl].sort((a,b)=>eff(b)-eff(a));
  const maxEff=effRank.length?eff(effRank[0]):1;

  const Alert=({type,icon,msg})=>{
    const col=type==="alert"?C.pk:type==="warn"?C.or:C.bl;
    return(<div style={{background:col+"10",borderLeft:"4px solid "+col,borderRadius:10,padding:"11px 14px",display:"flex",gap:10,marginBottom:9}}>
      <span style={{fontSize:14,flexShrink:0}}>{icon}</span>
      <span style={{fontSize:12,color:C.dk,lineHeight:1.6}}>{msg}</span>
    </div>);
  };

  const secs=[{id:"resumen",lbl:"Resumen"},{id:"eficiencia",lbl:"Eficiencia"},{id:"graficos",lbl:"Gráficos"},{id:"creativos",lbl:"Creativos"}];

  return(
    <div>
      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:18}}>
        {secs.map(s=><button key={s.id} onClick={()=>setSec(s.id)} style={{background:sec===s.id?C.bk:"transparent",color:sec===s.id?C.wh:C.gy,border:"1.5px solid "+(sec===s.id?C.bk:C.lg),borderRadius:100,padding:"6px 14px",fontSize:12,fontWeight:600}}>{s.lbl}</button>)}
      </div>
      <ObjFilter objs={objs} active={objF} onChange={setObjF}/>

      {sec==="resumen"&&(
        <div>
          <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:11,marginBottom:20}}>
            <StatCard label="Gasto total" value={"CLP "+fmtM(tG)} accent={C.bk}/>
            <StatCard label="Total leads" value={tL} accent={C.bl}/>
            <StatCard label="CPL promedio" value={"$"+fmt(avg)} accent={C.bl}/>
            <StatCard label="Mejor CPL" value={best?"$"+fmt(best.cpl):"—"} sub={best?.nombre?.slice(0,22)} accent={C.bl}/>
            <StatCard label="Peor CPL" value={worst?"$"+fmt(worst.cpl):"—"} sub={worst?.nombre?.slice(0,22)} accent={C.pk}/>
            <StatCard label="En riesgo" value={tG>0?Math.round(criticals.reduce((a,c)=>a+c.gasto,0)/tG*100)+"%":"0%"} sub="CPL > 2x promedio" accent={criticals.length>0?C.or:C.bl}/>
          </div>
          {best&&worst&&worst.cpl/best.cpl>4&&<Alert type="alert" icon="🚨" msg={"Brecha "+Math.round(worst.cpl/best.cpl)+"x: "+worst.nombre.slice(0,30)+" cuesta "+Math.round(worst.cpl/best.cpl)+"x más por lead que "+best.nombre.slice(0,30)+"."}/>}
          {criticals.length>0&&<Alert type="alert" icon="💸" msg={"CLP "+fmt(criticals.reduce((a,c)=>a+c.gasto,0))+" en "+criticals.length+" campaña(s) con CPL > 2x promedio. Redirigir a "+best?.nombre?.slice(0,25)+" generaría ~"+Math.round(criticals.reduce((a,c)=>a+c.gasto,0)*.6/(best?.cpl||1))+" leads adicionales."}/>}
          {noLeads.length>0&&<Alert type="alert" icon="🗑️" msg={noLeads.length+" campaña(s) gastaron CLP "+fmt(noLeads.reduce((a,c)=>a+c.gasto,0))+" sin generar ningún lead."}/>}
          {saturated.length>0&&<Alert type="warn" icon="🔁" msg={saturated.length+" campaña(s) con frecuencia >4x. Creativos nuevos necesarios."}/>}
          {smallAud.length>0&&<Alert type="warn" icon="👥" msg={smallAud.length+" campaña(s) con alcance <12k personas. Adv+ no puede optimizar."}/>}
          {funnelAds.length>0&&<Alert type="info" icon="📝" msg={funnelAds.length+" anuncio(s) con calidad alta pero conversión baja. Simplificar formulario a máx 3 campos."}/>}
          {best&&<Alert type="info" icon="🏆" msg={"Más eficiente: "+best.nombre+" → $"+fmt(best.cpl)+"/lead · "+eff(best).toFixed(2)+" leads por cada 1.000 CLP."}/>}
        </div>
      )}

      {sec==="eficiencia"&&(
        <div>
          <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
            <div style={{fontSize:13,fontWeight:700,marginBottom:3}}>Leads por cada 1.000 CLP gastados</div>
            <div style={{fontSize:11,color:C.gy,marginBottom:18}}>Promedio cuenta: {(tL/(tG/1000)).toFixed(2)}</div>
            {effRank.map((c,i)=>{
              const p=maxEff>0?(eff(c)/maxEff)*100:0;
              const col=eff(c)>=eff(effRank[0])*.7?C.bl:eff(c)>=eff(effRank[0])*.4?C.or:C.pk;
              return(
                <div key={i} style={{display:"grid",gridTemplateColumns:"22px 1fr 90px 65px",gap:10,alignItems:"center",marginBottom:10}}>
                  <div style={{width:20,height:20,borderRadius:5,background:i<2?C.bl:C.lg,display:"flex",alignItems:"center",justifyContent:"center",fontSize:9,fontWeight:700,color:i<2?C.wh:C.gy}}>{i+1}</div>
                  <div>
                    <div style={{fontSize:11,fontWeight:600,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{c.nombre}</div>
                    <div style={{height:4,background:C.lg,borderRadius:2,marginTop:4}}><div style={{width:p+"%",height:"100%",background:col,borderRadius:2}}/></div>
                  </div>
                  <div style={{textAlign:"center"}}><span style={{fontWeight:700,color:col,fontSize:12}}>{eff(c).toFixed(2)}</span><span style={{fontSize:9,color:C.gy}}> l/1kCLP</span></div>
                  <div style={{textAlign:"right",fontSize:10,color:C.gy}}>
                    <div style={{fontWeight:600}}>{tG>0?Math.round(c.gasto/tG*100):0}%</div>
                    <div>{c.leads} leads</div>
                  </div>
                </div>
              );
            })}
          </div>
          <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
            <div style={{fontSize:13,fontWeight:700,marginBottom:3}}>Desbalance gasto vs leads</div>
            <div style={{fontSize:11,color:C.gy,marginBottom:16}}>Campañas con mayor diferencia entre % de gasto y % de leads generados</div>
            {cwl.map((c,i)=>{
              const pg=tG>0?Math.round(c.gasto/tG*100):0;
              const pl=tL>0?Math.round(c.leads/tL*100):0;
              const diff=pg-pl;
              const waste=diff>8, under=diff<-8;
              return(
                <div key={i} style={{background:waste?C.pk+"08":under?C.bl+"08":C.cr,borderRadius:9,padding:"10px 13px",marginBottom:7,border:"1px solid "+(waste?C.pk+"25":under?C.bl+"25":C.lg)}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6,flexWrap:"wrap",gap:6}}>
                    <span style={{fontSize:11,fontWeight:700}}>{c.nombre.slice(0,45)}</span>
                    {waste&&<Pill color={C.pk}>Gasto alto, poco retorno</Pill>}
                    {under&&<Pill color={C.bl}>Subfinanciada</Pill>}
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
                    {[["% gasto",pg+"%" ,waste?C.pk:C.bk],["% leads",pl+"%",under?C.bl:C.bk],["Δ",(diff>0?"+":"")+diff+"pp",waste?C.pk:under?C.bl:C.gy]].map(([l,v,co])=>(
                      <div key={l}><div style={{fontSize:9,color:C.gy,fontWeight:700,textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:2}}>{l}</div><div style={{fontSize:15,fontWeight:700,color:co}}>{v}</div></div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {sec==="graficos"&&(
        <div>
          {cwl.length>0&&(
            <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
              <div style={{fontSize:13,fontWeight:700,marginBottom:3}}>CPL por campaña</div>
              <div style={{fontSize:11,color:C.gy,marginBottom:18}}>Rojo = más caro · azul = más eficiente</div>
              <BarChart data={cwl.slice(0,10)} valueKey="cpl" labelKey="nombre" height={180}/>
            </div>
          )}
          {setsWL.length>0&&(
            <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)",marginBottom:14}}>
              <div style={{fontSize:13,fontWeight:700,marginBottom:3}}>Alcance vs CPL — conjuntos</div>
              <div style={{fontSize:11,color:C.gy,marginBottom:16}}>Barra = audiencia · color = CPL vs promedio</div>
              {setsWL.map((s,i)=>{
                const maxA=setsWL[0]?.alcance||1;
                const p=Math.min((s.alcance/maxA)*100,100);
                const col=s.cpl>avgSetCPL*2?C.pk:s.cpl>avgSetCPL*1.3?C.or:C.bl;
                return(
                  <div key={i} style={{display:"grid",gridTemplateColumns:"130px 1fr 80px",gap:10,alignItems:"center",marginBottom:8}}>
                    <div style={{fontSize:10,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",color:s.cpl<avgSetCPL?C.bk:C.gy,fontWeight:s.cpl<avgSetCPL?600:400}}>{s.nombre}</div>
                    <div><div style={{height:5,background:C.lg,borderRadius:3}}><div style={{width:p+"%",height:"100%",background:col,borderRadius:3}}/></div><div style={{fontSize:9,color:C.gy,marginTop:2}}>{fmt(s.alcance)} personas</div></div>
                    <div style={{fontSize:11,fontWeight:700,color:col,textAlign:"right",fontFamily:"monospace"}}>${fmt(s.cpl)}</div>
                  </div>
                );
              })}
            </div>
          )}
          {camps.length>0&&(
            <div style={{background:C.wh,borderRadius:14,padding:"20px 22px",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <div style={{fontSize:13,fontWeight:700,marginBottom:3}}>Distribución de presupuesto</div>
              <div style={{fontSize:11,color:C.gy,marginBottom:16}}>% del gasto total por campaña</div>
              {[...camps].sort((a,b)=>b.gasto-a.gasto).slice(0,8).map((c,i)=>{
                const p=tG>0?(c.gasto/tG)*100:0;
                const col=p>20?C.pk:p>10?C.or:C.bl;
                return(
                  <div key={i} style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,alignItems:"center",marginBottom:10}}>
                    <div style={{fontSize:11,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{c.nombre}</div>
                    <div style={{display:"flex",alignItems:"center",gap:8}}><div style={{flex:1,height:5,background:C.lg,borderRadius:3}}><div style={{width:p+"%",height:"100%",background:col,borderRadius:3}}/></div><span style={{fontSize:11,fontWeight:700,color:col,minWidth:32}}>{p.toFixed(1)}%</span></div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}

      {sec==="creativos"&&(
        <div>
          {funnelAds.length>0&&(
